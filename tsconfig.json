{
	"compilerOptions": {
		"rewriteRelativeImportExtensions": true,
		"allowJs": true,
		"checkJs": true,
		"declaration": true,
		"forceConsistentCasingInFileNames": true,
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"outDir": "./dist",

		"paths": {
			"$types/*": ["./src/lib/types/*"],
			"$components/*": ["./src/lib/components/*"],
			"$styles/*": ["./src/lib/styles/*"],
			"$lib/*": ["./src/lib/*"]
		}
	}
}